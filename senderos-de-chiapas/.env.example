# Resend: clave API para el formulario de contacto (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Strapi (Fly.io o tu instancia). En Vercel configurar la URL pública de Strapi.
# STRAPI_URL se usa en el servidor; NEXT_PUBLIC_STRAPI_URL también en el cliente (ej. imágenes).
STRAPI_URL=https://tu-app-strapi.fly.dev
NEXT_PUBLIC_STRAPI_URL=https://tu-app-strapi.fly.dev
STRAPI_TOKEN=
