{
  "kind": "collectionType",
  "collectionName": "holidays",
  "info": {
    "singularName": "holiday",
    "pluralName": "holidays",
    "displayName": "Paquetes por Temporada"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "home": {
      "type": "boolean"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "route": {
      "type": "blocks"
    },
    "transport": {
      "type": "string"
    },
    "departure": {
      "type": "string"
    },
    "includes": {
      "type": "blocks"
    },
    "duration": {
      "type": "string"
    },
    "accommodation": {
      "type": "string"
    },
    "price": {
      "type": "string"
    },
    "departureDate": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "imagesDetails": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "badge": {
      "type": "enumeration",
      "enum": [
        "nuevo",
        "pocos_lugares",
        "agotado",
        "oculto"
      ]
    },
    "calendarStart": {
      "type": "date"
    },
    "calendarEnd": {
      "type": "date"
    },
    "itineraryItem": {
      "type": "component",
      "component": "itinerary.itinerary-item",
      "repeatable": true
    },
    "mapItem": {
      "type": "component",
      "component": "map.map-item",
      "repeatable": true
    }
  }
}
